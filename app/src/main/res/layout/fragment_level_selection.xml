<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:clipChildren="false"
    android:clipToPadding="false"
    android:padding="8dp"
    android:background="#4CAF50">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:background="@drawable/bg_level_screen">

        <!-- Title bar -->
        <TextView
            android:id="@+id/level_selection_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/level_selection_title"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textAlignment="center"
            android:gravity="center"
            android:textColor="#FFFFFF"
            android:shadowColor="#80000000"
            android:shadowDx="1"
            android:shadowDy="1"
            android:shadowRadius="3"
            android:paddingTop="12dp"
            android:paddingBottom="4dp"
            app:layout_constraintEnd_toStartOf="@id/user_profile_button"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- User profile button at top right -->
        <Button
            android:id="@+id/user_profile_button"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:textSize="16sp"
            android:padding="0dp"
            android:layout_marginTop="8dp"
            android:layout_marginEnd="8dp"
            android:background="@drawable/button_fancy_blue"
            android:elevation="4dp"
            android:contentDescription="@string/user_profile_button_a11y"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Progress bar area -->
        <LinearLayout
            android:id="@+id/progress_container"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="4dp"
            android:paddingBottom="8dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/level_selection_title">

            <!-- Total stars count (large golden number) -->
            <TextView
                android:id="@+id/total_stars_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#FFD700"
                android:textSize="28sp"
                android:textStyle="bold"
                android:shadowColor="#80000000"
                android:shadowDx="1"
                android:shadowDy="1"
                android:shadowRadius="2"
                android:layout_marginEnd="4dp" />

            <!-- Star icon -->
            <ImageView
                android:id="@+id/progress_checkmark"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/star"
                android:importantForAccessibility="no" />

            <!-- Progress bar with diagonal separator and floating text -->
            <FrameLayout
                android:layout_width="0dp"
                android:layout_height="32dp"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="8dp"
                android:clipChildren="false"
                android:clipToPadding="false">

                <!-- Progress bar background (blue) -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_progress_bar" />

                <!-- Progress fill (yellow) -->
                <View
                    android:id="@+id/progress_fill"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_progress_fill" />

                <!-- Diagonal SVG separator positioned at the edge of the fill -->
                <ImageView
                    android:id="@+id/progress_diagonal"
                    android:layout_width="20dp"
                    android:layout_height="match_parent"
                    android:src="@drawable/progress_diagonal_separator"
                    android:scaleType="fitXY"
                    android:importantForAccessibility="no" />

                <!-- Text layer floating above the bar (z-order) -->
                <LinearLayout
                    android:id="@+id/progress_text_container"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:clipChildren="false"
                    android:clipToPadding="false">

                    <!-- Left text (linksbündig) -->
                    <TextView
                        android:id="@+id/progress_text_left"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="start|center_vertical"
                        android:paddingStart="8dp"
                        android:paddingEnd="4dp"
                        android:textColor="#FFFFFF"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:shadowColor="#80000000"
                        android:shadowDx="1"
                        android:shadowDy="1"
                        android:shadowRadius="2"
                        android:ellipsize="none" />

                    <!-- Right text (rechtsbündig) -->
                    <TextView
                        android:id="@+id/progress_text_right"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="end|center_vertical"
                        android:paddingStart="4dp"
                        android:paddingEnd="8dp"
                        android:textColor="#FFFFFF"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:shadowColor="#80000000"
                        android:shadowDx="1"
                        android:shadowDy="1"
                        android:shadowRadius="2"
                        android:ellipsize="none" />
                </LinearLayout>
            </FrameLayout>

        </LinearLayout>

        <!-- Scroll up arrow button (shown when not at top) -->
        <Button
            android:id="@+id/scroll_up_arrow"
            android:layout_width="220dp"
            android:layout_height="32dp"
            android:text="▲"
            android:textSize="20sp"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:background="@drawable/button_fancy_blue"
            android:elevation="8dp"
            android:visibility="gone"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/progress_container" />

        <!-- RecyclerView for level grid -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/level_recycler_view"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="0dp"
            android:paddingBottom="6dp"
            android:clipToPadding="true"
            android:clipChildren="true"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/scroll_up_arrow"
            app:layout_constraintBottom_toBottomOf="parent" />

        <!-- Bottom button row - overlaps bottom border by half -->
        <LinearLayout
            android:id="@+id/bottom_button_row"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingBottom="0dp"
            android:paddingTop="0dp"
            android:translationY="7dp"
            android:elevation="8dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <Button
                android:id="@+id/back_button"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/back"
                android:contentDescription="@string/back_description"
                android:paddingTop="10dp"
                android:paddingBottom="10dp"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="16sp"
                android:textAllCaps="true"
                android:background="@drawable/bg_back_button" />

            <Button
                android:id="@+id/level_editor_button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/level_editor_button_short"
                android:paddingTop="10dp"
                android:paddingBottom="10dp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="16sp"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_back_button"
                android:visibility="gone" />
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</FrameLayout>
