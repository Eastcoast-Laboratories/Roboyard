<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="4dp">

    <!-- Card container - background set programmatically (gold/blue/locked) -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/level_card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_level_card_blue"
        android:clickable="true"
        android:focusable="true"
        android:foreground="?android:attr/selectableItemBackground"
        android:padding="4dp">

        <!-- Stars row at top left -->
        <LinearLayout
            android:id="@+id/stars_container"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="start"
            android:layout_marginStart="2dp"
            android:layout_marginTop="2dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:id="@+id/level_star_1"
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:layout_marginEnd="1dp"
                android:src="@drawable/star"
                android:visibility="gone"
                android:importantForAccessibility="no" />

            <ImageView
                android:id="@+id/level_star_2"
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:layout_marginEnd="1dp"
                android:src="@drawable/star"
                android:visibility="gone"
                android:importantForAccessibility="no" />

            <ImageView
                android:id="@+id/level_star_3"
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:layout_marginEnd="1dp"
                android:src="@drawable/star"
                android:visibility="gone"
                android:importantForAccessibility="no" />

            <ImageView
                android:id="@+id/level_star_4"
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:src="@drawable/star"
                android:visibility="gone"
                android:importantForAccessibility="no" />
        </LinearLayout>

        <!-- Info button at top right (for completed levels with history) -->
        <ImageButton
            android:id="@+id/level_info_button"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_marginEnd="2dp"
            android:layout_marginTop="0dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_info_details"
            android:scaleType="fitCenter"
            android:visibility="gone"
            android:contentDescription="@string/info_button_a11y"
            app:tint="#000000"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Minimap image (shown for completed levels with history) -->
        <ImageView
            android:id="@+id/level_minimap_view"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginTop="2dp"
            app:layout_constraintDimensionRatio="1:1"
            android:scaleType="centerCrop"
            android:importantForAccessibility="no"
            android:visibility="gone"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/stars_container" />

        <!-- Level number overlay on minimap (shown for completed levels) -->
        <TextView
            android:id="@+id/minimap_level_number"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:shadowColor="#000000"
            android:shadowDx="1"
            android:shadowDy="1"
            android:shadowRadius="2"
            android:visibility="gone"
            app:layout_constraintBottom_toBottomOf="@id/level_minimap_view"
            app:layout_constraintEnd_toEndOf="@id/level_minimap_view"
            app:layout_constraintStart_toStartOf="@id/level_minimap_view"
            app:layout_constraintTop_toTopOf="@id/level_minimap_view" />

        <!-- Large level number (shown for playable / not-yet-played levels) -->
        <TextView
            android:id="@+id/level_number_text"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginTop="2dp"
            app:layout_constraintDimensionRatio="W,9:8"
            android:gravity="center"
            android:textColor="#FFFFFF"
            android:textSize="36sp"
            android:textStyle="bold"
            android:shadowColor="#40000000"
            android:shadowDx="2"
            android:shadowDy="2"
            android:shadowRadius="3"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/stars_container" />

        <!-- Lock icon (shown for locked levels) -->
        <ImageView
            android:id="@+id/lock_icon"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginTop="8dp"
            android:src="@drawable/ic_lock"
            android:visibility="gone"
            android:importantForAccessibility="no"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/stars_container"
            app:layout_constraintBottom_toTopOf="@id/locked_level_label"
            app:layout_constraintVertical_chainStyle="packed" />

        <!-- Level label for locked levels (shown below lock icon) -->
        <TextView
            android:id="@+id/locked_level_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            android:textStyle="bold"
            android:layout_marginTop="2dp"
            android:layout_marginBottom="4dp"
            android:visibility="gone"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/lock_icon"
            app:layout_constraintBottom_toBottomOf="parent" />

        <!-- Play arrow indicator (bottom right, for playable levels) -->
        <ImageView
            android:id="@+id/play_arrow"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:layout_marginEnd="2dp"
            android:layout_marginBottom="2dp"
            android:src="@drawable/ic_play_arrow"
            android:visibility="gone"
            android:importantForAccessibility="no"
            app:layout_constraintBottom_toBottomOf="@id/level_number_text"
            app:layout_constraintEnd_toEndOf="@id/level_number_text" />

        <!-- Level name label at bottom (for completed levels) -->
        <TextView
            android:id="@+id/level_name_text"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:textColor="#FFFFFF"
            android:textSize="10sp"
            android:textStyle="bold"
            android:shadowColor="#80000000"
            android:shadowDx="1"
            android:shadowDy="1"
            android:shadowRadius="1"
            android:paddingBottom="2dp"
            android:visibility="gone"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/level_number_text" />

        <!-- Hidden views for compatibility with existing code -->
        <Button
            android:id="@+id/level_button"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:visibility="gone"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <LinearLayout
            android:id="@+id/stats_overlay"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:orientation="vertical"
            android:visibility="gone"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">
            <TextView android:id="@+id/level_moves_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:visibility="gone" />
            <TextView android:id="@+id/level_time_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:visibility="gone" />
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</FrameLayout>
