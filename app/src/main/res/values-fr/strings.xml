    <!-- Help screen -->
    <string name="help_screen_content_title">Comment jouer à Roboyard</string>
    <string name="help_goal_section_title">Objectif</string>
    <string name="help_goal_description">Déplacez les robots colorés vers leurs cibles de couleur correspondante. Le jeu est terminé lorsque tous les robots sont sur leurs cibles correspondantes.</string>
    <string name="help_movement_section_title">Mouvement</string>
    <string name="help_movement_point_1">- Tapez sur un robot pour le sélectionner.</string>
    <string name="help_movement_point_2">- Tapez sur une case vide pour déplacer le robot sélectionné dans cette direction.</string>
    <string name="help_movement_point_3">- Les robots se déplacent en ligne droite jusqu\'à ce qu\'ils heurtent un mur, un autre robot ou le bord du plateau.</string>
    <string name="help_controls_section_title">Contrôles</string>
    <string name="help_controls_point_1">- Indice: Montre un mouvement suggéré.</string>
    <string name="help_controls_point_2">- Réinitialiser: Redémarre le niveau actuel.</string>
    <string name="help_controls_point_3">- Sauvegarder: Sauvegarde votre carte actuelle.</string>
    <string name="help_controls_point_4">- Menu: Retourne au menu principal.</string>
    <string name="help_accessibility_section_title">Accessibilité</string>
    <string name="help_accessibility_description">Ce jeu est entièrement compatible avec le lecteur d\'écran TalkBack. Utilisez l\'exploration tactile pour entendre les informations sur les éléments du jeu et les boutons. Appuyez deux fois pour activer les boutons ou sélectionner des robots.</string>
    <string name="help_tips_section_title">Conseils</string>
    <string name="help_tips_point_1">- Essayez de résoudre les énigmes avec le minimum de mouvements.</string>
    <string name="help_tips_point_2">- Parfois, vous devez déplacer les robots à des positions spécifiques pour dégager les chemins pour d\'autres robots.</string>
    <string name="help_tips_point_3">- Si vous êtes bloqué, utilisez la fonction Indice pour obtenir une suggestion.</string>
    
